# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Set to true to skip on-chain calls and write mock records to SQLite.
# Use this to verify the DB layer before the relayer wallet is funded.
DRY_RUN=true

# ─── SQLite ───────────────────────────────────────────────────────────────────
# Local dev: omit (defaults to ./nova.db next to package.json)
# Railway:   set to /data/nova.db and mount a volume at /data
DB_PATH=./nova.db

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # from: stripe listen --forward-to localhost:3001/webhooks/stripe

# ─── Base ─────────────────────────────────────────────────────────────────────
# Testnet (Base Sepolia) for verification gate before mainnet:
BASE_RPC_URL=https://sepolia.base.org

# Mainnet (flip when verified):
# BASE_RPC_URL=https://mainnet.base.org

# Relayer = oracle wallet 0x24A4...D849
# ⚠ BLOCKER: fund this address with ETH on whichever network you're targeting
RELAYER_PRIVATE_KEY=0x...

# Nova worker wallet — receives USDC on escrow release after kit delivery
NOVA_WORKER_ADDRESS=0x9e80b1aa9c7C2a8B875CC569D8E30cEfB364c9aD

# TaskEscrowV2 (Base Mainnet, verified)
TASK_ESCROW_ADDRESS=0xBE464859Fb6f09fa93b6212f616F3AD19ebe48B1

# USDC contract address
# Base Mainnet:  0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Base Sepolia:  0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Amount to lock in USDC (6 decimals). $9.00 = 9000000 (keeps $0.99 for gas margin)
USDC_LOCK_AMOUNT=9000000

# ─── Claude ───────────────────────────────────────────────────────────────────
# ⚠ BLOCKER: credits depleted — top up before Nova chat works
ANTHROPIC_API_KEY=sk-ant-...

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=https://zylogen.xyz

# Extra CORS origins (comma-separated). The canonical domains are always allowed.
# Add Vercel preview URLs here when testing specific deployments.
# e.g. ALLOWED_ORIGINS=https://zylogen-git-feature-x.vercel.app
ALLOWED_ORIGINS=
